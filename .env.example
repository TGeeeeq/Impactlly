# Supabase Configuration
# Get these from: https://app.supabase.com/project/[PROJECT_ID]/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://[PROJECT_ID].supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Supabase Service Role Key (for server-side operations)
# WARNING: Keep this secret, never expose to client
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Vercel Blob Storage
# Get from: Vercel Settings → Storage → Blob → Tokens
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_...

# OpenAI API Key (for image verification)
# Get from: https://platform.openai.com/account/api-keys
OPENAI_API_KEY=sk-...

# Optional: OAuth Configuration
# Google OAuth (for sign-up flow)
# NEXT_PUBLIC_GOOGLE_CLIENT_ID=...
# GOOGLE_CLIENT_SECRET=...

# Apple OAuth (for sign-up flow)
# APPLE_CLIENT_ID=...
# APPLE_TEAM_ID=...
# APPLE_KEY_ID=...

# Optional: Analytics
# NEXT_PUBLIC_SENTRY_DSN=...
# NEXT_PUBLIC_MIXPANEL_TOKEN=...

# Development Only
NODE_ENV=development
